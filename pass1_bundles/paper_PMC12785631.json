      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": "discussion_1",
      "text": "AURKA has been shown to phosphorylate P53 at Ser315, leading to its ubiquitination by MDM2 and subsequent proteolysis.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "case-control study",
      "eco_type": null,
      "source": "extracted"
    },
    {
