  "evidence_entities": [
    {
      "id": "paper_1:background:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "background_1",
      "text": "HRD subtyping identified distinct genomic, pathological, and immunological features. HRD-High tumours were associated with advanced FIGO stages, TP53 mutations, higher chromosomal instability, and elevated CD8\u207aPD-1\u207a T-cell infiltration.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:background:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "background_2",
      "text": "HRD subtyping independently predicted disease-free survival and showed superior prognostic accuracy (C-index = 0.857) compared to TCGA subtyping (C-index = 0.751).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:background:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "background_3",
      "text": "Integrating HRD and TCGA classifiers further improved predictive performance (C-index = 0.903).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:background:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "background_4",
      "text": "An SVM model incorporating HRD score and immune features achieved an AUC of 0.733 for recurrence prediction.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "results_1",
      "text": "HRD-High patients exhibited significantly elevated numbers of CD3+PD-1+ T cells and CD8+PD-1+ T cells in their tumour-immune microenvironment compared to HRD-Middle and HRD-Low groups (all p < 0.05).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "results_2",
      "text": "Higher densities of CD3+ T cells (in both parenchyma and stroma), CD8+ T cells (in parenchyma), M1 macrophages (in parenchyma), and M2 macrophages (in stroma) were associated with a lower risk of recurrence or progression.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:discussion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "discussion_1",
      "text": "HRD-High tumours may represent a subset of tumours with potential responsiveness to immune checkpoint inhibitors, particularly when used in combination with DNA damage-targeted therapies.",
      "confidence": 0.85,
      "extraction_method": "llm",
      "study_type": "retrospective cohort study",
