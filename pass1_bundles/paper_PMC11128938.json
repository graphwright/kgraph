  "evidence_entities": [
    {
      "id": "extracted:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "abstract_1",
      "text": "Desmopressin is increasingly used for the diagnosis of Cushing disease (CD) since corticotropin-releasing hormone became unavailable.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:abstract:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "abstract_2",
      "text": "Intravenous desmopressin administration produced no ACTH or cortisol increase.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:abstract:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "abstract_3",
      "text": "Inferior petrosal sinus sampling (IPSS) with desmopressin stimulation resulted in elevated central-to-peripheral ACTH ratio and prolactin co-secretion, while peripheral ACTH remained stable.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "introduction_1",
      "text": "The mechanism by which desmopressin stimulates ACTH secretion in CD may result from overexpression of AVPR1B receptors as well as ectopic AVPR2 receptors in corticotroph adenomas, which is more prevalent in tumors harboring USP8 mutations.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:case:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "case_1",
      "text": "A desmopressin (10 \u03bcg IV) stimulation test showed no response: ACTH remained stable from 3.8 pmol/L (17.3 pg/mL) to 3.9 pmol/L and cortisol from 688 nmol/L (25 \u03bcg/dL) to 622 nmol/L (23 \u03bcg/dL).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:case:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "case_2",
      "text": "IPSS performed with desmopressin suggested a pituitary origin with central-to-peripheral (C/P) ACTH ratios that rose from 7.1 to 34.2 on the left.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:treatment:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "treatment_1",
      "text": "However, pathology showed normal pituitary tissue with rare Crooke's cells, suggesting cortisol excess.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:outcome:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "outcome_1",
      "text": "Two weeks later, the patient was admitted to the emergency unit with nausea, vomiting, and lethargy. Upon evaluation, the patient was found to be hypotensive (80/50 mmHg), hyponatremic (132 mmol/L, normal: 135\u2013145 mmol/L), and mildly hypoglycemic (3.7 mmol/L [67 mg/dL], normal range: 4.0\u201311.1 nmol/L; 72\u2013200 mg/dL).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:outcome:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "outcome_2",
      "text": "AI was diagnosed, and the patient's condition promptly resolved with IV hydrocortisone and fluid resuscitation.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:discussion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "discussion_1",
      "text": "According to a recent meta-analysis, the desmopressin stimulation test has a sensitivity of 88% for discriminating CD from normal patients with clinical or biochemical features suggestive of CS, indicating nonetheless a false-negative rate of 12%.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted:discussion:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted",
      "text_span_id": "discussion_2",
      "text": "A meta-analysis comparing desmopressin and CRH stimulation during IPSS found that desmopressin had high sensitivity (96%) and specificity (100%), similar to CRH, for distinguishing CD from EAS.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    }
  ],
