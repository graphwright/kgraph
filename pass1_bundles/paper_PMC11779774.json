  "evidence_entities": [
    {
      "id": "PMC_UNKNOWN:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "intro_1",
      "text": "Cushing's disease (CD) is caused by an adrenocorticotropic hormone (ACTH)-producing pituitary adenoma and is the most common cause of endogenous Cushing's syndrome",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "intro_2",
      "text": "The annual incidence of CD is 1.5/million, and the prevalence is 57 cases per million, with a female predominance",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:introduction:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "intro_3",
      "text": "Despite its rare occurrence, the disorder is associated with commonly encountered comorbidities including hypertension, obesity, dyslipidemia, atherosclerosis, hypercoagulability, osteoporosis and fractures, impaired glucose metabolism, and immune and growth suppression",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:introduction:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "intro_4",
      "text": "Higher mortality rates reported in CD, mainly due to cardiovascular causes, were associated with persistent disease",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:introduction:5:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "intro_5",
      "text": "Remission rates after surgery are dependent on surgeon expertise and may reach 83% for microadenomas and 68% for macroadenomas in PTCOEs",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "results_1",
      "text": "Ketoconazole was the most frequently used drug, with a median rate of usage of 26.5% (5-66.7) of those receiving medical therapy",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "results_2",
      "text": "The median rates of metyrapone and pasireotide use were 17.2% (0\u201350) and 9.3% (0-51.7), respectively",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "results_3",
      "text": "Overall, the median control rate in patients with CD receiving medical treatment was 75% (10\u2013100)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "results_4",
      "text": "The median biochemical control rate of ketoconazole provided by 7 centers was 76% (range: 20\u2013100)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_UNKNOWN:results:5:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_UNKNOWN",
      "text_span_id": "results_5",
      "text": "Biochemical control rates with pasireotide and metyrapone, available from 5 centers, were 80% (range: 50\u2013100) and 60% (range: 10\u201380), respectively",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "cross-sectional study",
      "eco_type": null,
      "source": "extracted"
    }
