  "evidence_entities": [
    {
      "id": "PMC_extracted:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_1",
      "text": "At 28 days after injury, compared with the sham group, the hSCI group displayed scar formation and dramatic elevations in the mean interleukin 1 beta (IL-1\u03b2) density and cell apoptosis level, whereas the expression of signal transducer and activator of transcription 3 (STAT3) and ciliary neurotrophic factor (CNTF) mRNA was reduced.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_2",
      "text": "Following BMSC transplantation, motoneurons extent of shrinkage were reduced and the animals' Basso, Beattie, and Bresnahan (BBB) locomotion scale scores were significantly higher at 21 and 28 days after injury when compared with the injured group.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_3",
      "text": "Moreover, the hSCI-induced elevations in scar formation, IL-1\u03b2, and cell apoptosis were reduced by BMSC transplantation to levels that were close to those of the sham group.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_4",
      "text": "Corresponding elevations in the expression of STAT3 and CNTF mRNA were observed in the hSCI + BMSCs group, and the levels were not significantly different from those observed in the sham group.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:conclusion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "conclusion_1",
      "text": "Together, our results support that grafted BMSCs can significantly improve locomotor function in tree shrews subjected to hSCI and that this improvement is associated with the upregulation of CNTF and STAT3 signaling.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "animal_model",
      "source": "extracted"
    }
  ],
