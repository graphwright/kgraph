  "evidence_entities": [
    {
      "id": "paper_id:methods:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "methods_1",
      "text": "Methylation\u2010specific polymerase chain reaction (PCR) was used to identify the methylation levels of BRD7 promoter.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
      "source": "extracted"
    },
    {
      "id": "paper_id:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_1",
      "text": "There was hypermethylation modification in BRD7 promoter, which was negatively correlated with BRD7 expression.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
      "source": "extracted"
    },
    {
      "id": "paper_id:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_2",
      "text": "We constructed a LentiCRISPRv2/dCas9\u2010TET1CD\u2010sgRNAs system targeting specific methylation sites of BRD7 promoter based on five sgRNAs, and confirmed that all five sgRNA\u2010guided CRISPR/dCas9 systems could activate BRD7 and inhibit cell proliferation to varying degrees, among which sgRNA2&sgRNA5 were the most significant.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
      "source": "extracted"
    },
    {
      "id": "paper_id:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_3",
      "text": "Both sgRNA2&sgRNA5 could promote the transcriptional activation by reducing its methylation, and inhibit the cell proliferation, migration, invasion and tumour growth in vivo of NPC, and the combination of them has a more significant demethylation, transcriptional activation and anti\u2010tumour effect.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vivo",
      "source": "extracted"
    },
    {
      "id": "paper_id:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_4",
      "text": "BRD7 had hypermethylation modification in its promoter and decreased expression in NPC tissues, and both of them were negatively correlated, making it a potential diagnostic marker for NPC diagnosis.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "clinical",
      "source": "extracted"
    },
    {
      "id": "paper_id:results:5:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_5",
      "text": "The LV\u2010dCas9\u2010TET1CD\u2010sgRNA2 and sgRNA5 groups were significantly reduced, with tumour suppression rates of 68% and 79%, respectively. Among them, the combination group exhibited the most pronounced suppression effect, with a tumour suppression rate of 90%.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vivo",
      "source": "extracted"
    }
