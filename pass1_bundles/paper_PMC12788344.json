  "evidence_entities": [
    {
      "id": "paper_id:case_overview:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "case_overview_1",
      "text": "A 36\u2010year\u2010old, nulligravid woman with a history of controlled eosinophilic esophagitis, asthma, and dense fibrocystic breasts was referred to the Breast Health Center after abnormal screening mammography.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:case_overview:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "case_overview_2",
      "text": "She completed a comprehensive 76\u2010gene germline genetic test, which revealed tumor protein p53 (TP53) likely pathogenic variant (LPV; c.716A>G; p.N239S).",
      "confidence": 0.98,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:genetics:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "genetics_1",
      "text": "When TP53 PVs/LPVs are identified in a comprehensive germline panel, this raises concern for Li\u2013Fraumeni syndrome (LFS).",
      "confidence": 0.98,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:genetics:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "genetics_2",
      "text": "LFS is a hereditary cancer syndrome that is associated with increased risk for multiple cancers, including, but not limited to, breast cancer, sarcoma, central nervous system tumors, and adrenocortical carcinoma.",
      "confidence": 0.98,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:genetics:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "genetics_3",
      "text": "The same specific TP53 LPV (c.716A>G [p.N239S]) was detected in all three tumors.",
      "confidence": 0.98,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:genetics:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "genetics_4",
      "text": "In our patient, the VAF for the TP53 c.716A>G in each lesion was as follows: left breast DCIS, 2.4%; right breast DCIS, 33.9%; and left phyllodes tumor, 60.8%.",
      "confidence": 0.98,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:surgery:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "surgery_1",
      "text": "The breast cancer risk for women with LFS/germline TP53 LPVs/PVs is 80%\u201390%, with most breast cancers occurring at a younger age.",
      "confidence": 0.98,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:surgery:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "surgery_2",
      "text": "Furthermore, malignant phyllodes breast tumors in women are associated with LFS.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:radiation:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "radiation_1",
      "text": "In vitro studies suggest that TP53 PVs/LPVs are associated with increased radiosensitivity.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:radiation:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "radiation_2",
      "text": "It has been demonstrated that patients with LFS who receive radiation therapy have an increased risk of radiation\u2010related malignancies within irradiated areas.",
      "confidence": 0.98,
      "extraction_method": "llm",
      "study_type": "case report",
      "eco_type": null,
      "source": "extracted"
    }
