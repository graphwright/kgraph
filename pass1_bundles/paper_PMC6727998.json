  "evidence_entities": [
    {
      "id": "extracted_paper:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper",
      "text_span_id": "results_1",
      "text": "A reduction in the size of hypoesthetic area with TPI was observed in 27 (58.7%) patients. All the 27 patients experienced a reduction in pain intensity by more than 50% in a numerical rating scale score through TPI therapy.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted_paper:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper",
      "text_span_id": "results_2",
      "text": "In 9 patients, the reduction in the sizes of hypoesthetic areas occurred 10 minutes after TPI. Complete disappearance of tactile hypoesthesia after TPI therapy was observed in 6 of the 27 patients.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted_paper:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper",
      "text_span_id": "results_3",
      "text": "Myofascial trigger points were located in the muscles in the vicinity of ipsilateral cutaneous dermatomes to which the hypoesthetic areas belonged.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted_paper:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper",
      "text_span_id": "results_4",
      "text": "Thirty-four (74%) of 46 patients with MTrP had tactile hypoesthesia.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted_paper:discussion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper",
      "text_span_id": "discussion_1",
      "text": "Several brain imaging studies have shown that the activity of the primary somatosensory cortex decreases along with a decline in touch sensation.",
      "confidence": 0.85,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted_paper:discussion:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper",
      "text_span_id": "discussion_2",
      "text": "Such inhibition of neuronal activity in the somatosensory cortex induced by ongoing afferent nociceptive input from MTrP may underlie the reversible tactile hypoesthesia in patients with MPS.",
      "confidence": 0.8,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": null,
      "source": "extracted"
    }
