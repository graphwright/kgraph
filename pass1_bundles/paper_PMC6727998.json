  "evidence_entities": [
    {
      "id": "paper_id:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": null,
      "text": "Tactile hypoesthesia observed in patients with myofascial pain syndrome (MPS) is sometimes reversible when pain is relieved by trigger point injections (TPIs).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": null,
      "text": "A reduction in the size of hypoesthetic area with TPI was observed in 27 (58.7%) patients.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": null,
      "text": "All the 27 patients experienced a reduction in pain intensity by more than 50% in a numerical rating scale score through TPI therapy.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": null,
      "text": "Complete disappearance of tactile hypoesthesia after TPI therapy was observed in 6 of the 27 patients.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": null,
      "text": "Thirty-four (74%) of 46 patients with MTrP had tactile hypoesthesia.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "pilot study",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_id:discussion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": null,
      "text": "Such inhibition of neuronal activity in the somatosensory cortex induced by ongoing afferent nociceptive input from MTrP may underlie the reversible tactile hypoesthesia in patients with MPS.",
      "confidence": 0.85,
      "extraction_method": "llm",
