  "evidence_entities": [
    {
      "id": "paper_1:background:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "background_1",
      "text": "Endogenous Cushing syndrome denotes a group of rare diseases resulting from the body's over-excretion of cortisol. It can be characterised as adrenocorticotrophic hormone (ACTH)\u2013dependent or independent. The most common form of ACTH-dependent Cushing syndrome is Cushing disease, where there is a pituitary tumour that secretes ACTH, leading to an overproduction of cortisol.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "drug_review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:mechanism:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "mechanism_1",
      "text": "Osilodrostat is a potent inhibitor of 11-beta-hydroxylase, an enzyme that catalyses cortisol biosynthesis in the adrenal gland.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "drug_review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:clinical_trials:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "clinical_trials_1",
      "text": "More patients who continued osilodrostat maintained a complete response without any dose increases during this period compared with those on placebo (86.1% versus 29.4%).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "drug_review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:adverse_effects:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "adverse_effects_1",
      "text": "Hypocortisolism-related adverse events (mostly reported as adrenal insufficiency or glucocorticoid deficiency) occurred in 70/138 (51%) of patients across the entire study.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "drug_review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:adverse_effects:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "adverse_effects_2",
      "text": "Inhibition of 11-beta-hydroxylase is associated with the accumulation of adrenal steroid precursors and increased testosterone; in female participants, hirsutism and acne were reported in 11% and 12%, respectively.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "drug_review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:adverse_effects:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "adverse_effects_3",
      "text": "A decrease in serum potassium concentration was observed in some patients, with 7 (5%) patients developing severe hypokalaemia. QT interval prolongation was reported in 5 (4%) patients.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "drug_review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:precautions:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "precautions_1",
      "text": "In clinical studies, osilodrostat demonstrated mild to moderate inhibition of some cytochrome P450 (CYP) enzymes, such as CYP2D6, CYP3A4/5, CYP2C19 and CYP1A2.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "drug_review",
      "eco_type": null,
      "source": "extracted"
    }
