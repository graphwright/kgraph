  "evidence_entities": [
    {
      "id": "PMC11729654:abstract:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729654",
      "text_span_id": "abstract_1",
      "text": "Chimpanzee HCCs exhibited histological and immunohistochemical features similar to human tumors but displayed sharply divergent genomic landscapes. Chimpanzee tumors carried significantly higher coding mutation loads (mean 5632 per sample vs. 96\u2013275 in humans).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "comparative genomics",
      "eco_type": "whole-genome sequencing",
      "source": "extracted"
    },
    {
      "id": "PMC11729654:abstract:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729654",
      "text_span_id": "abstract_2",
      "text": "Non-synonymous TSC2 mutations occurred in 80% of chimpanzees, versus ~7% in human HCC, suggesting a species-specific oncogenic pathway linked to the scirrhous subtype.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "comparative genomics",
      "eco_type": "whole-genome sequencing",
      "source": "extracted"
    },
    {
      "id": "PMC11729654:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729654",
      "text_span_id": "results_1",
      "text": "TSC2 alterations are present in only 7% of human HCC patients, whereas 80% of chimpanzees with HCC in our study possessed TSC2 mutations.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "comparative genomics",
      "eco_type": "whole-genome sequencing",
      "source": "extracted"
    },
    {
      "id": "PMC11729654:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729654",
      "text_span_id": "results_2",
      "text": "On average per sample, 5632 mutations were found in chimpanzee samples, while 275 mutations were found in TCGA+ samples and 96 mutations were found in ICGC samples.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "comparative genomics",
      "eco_type": "whole-genome sequencing",
      "source": "extracted"
    },
    {
      "id": "PMC11729654:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729654",
      "text_span_id": "results_3",
      "text": "There were 10.5% more non-synonymous SNVs in humans compared with chimpanzees (61.7% non-synonymous in chimpanzee vs. 72.2% in human; Fisher's exact test, P < 2e-16).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "comparative genomics",
      "eco_type": "whole-genome sequencing",
      "source": "extracted"
    },
    {
      "id": "PMC11729654:discussion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729654",
      "text_span_id": "discussion_1",
      "text": "TSC2 is a tumor suppressor gene that encodes the protein Tuberin complexing with Hamartin, the protein encoded by TSC1, and together they inhibit the mammalian target of rapamycin (mTOR) pathway, which is crucial for cell growth, metabolism, and proliferation.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "comparative genomics",
      "eco_type": "whole-genome sequencing",
      "source": "extracted"
    }
  ],
