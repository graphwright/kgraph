  "evidence_entities": [
    {
      "id": "PMC11729386:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729386",
      "text_span_id": "results_1",
      "text": "Chimpanzee HCCs exhibited histological and immunohistochemical features similar to human tumors but displayed sharply divergent genomic landscapes. Chimpanzee tumors carried significantly higher coding mutation loads (mean 5632 per sample vs. 96\u2013275 in humans).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "comparative genomics",
      "eco_type": "whole-genome sequencing",
      "source": "extracted"
    },
    {
      "id": "PMC11729386:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729386",
      "text_span_id": "results_2",
      "text": "Non-synonymous TSC2 mutations occurred in 80% of chimpanzees, versus ~7% in human HCC, suggesting a species-specific oncogenic pathway linked to the scirrhous subtype.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "comparative genomics",
      "eco_type": "whole-exome sequencing",
      "source": "extracted"
    },
    {
      "id": "PMC11729386:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729386",
      "text_span_id": "results_3",
      "text": "Additional recurrently mutated genes included ARID1A, FAT1\u20134, TP53, and FGA.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "comparative genomics",
      "eco_type": "whole-exome sequencing",
      "source": "extracted"
    },
    {
      "id": "PMC11729386:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729386",
      "text_span_id": "results_4",
      "text": "Shared alterations across species involved canonical drivers such as TP53, CTNNB1, FAT4, and TTN.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "comparative genomics",
      "eco_type": "whole-exome sequencing",
      "source": "extracted"
    },
    {
      "id": "PMC11729386:discussion:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729386",
      "text_span_id": "discussion_1",
      "text": "TSC2 is a tumor suppressor gene that encodes the protein Tuberin complexing with Hamartin, the protein encoded by TSC1, and together they inhibit the mammalian target of rapamycin (mTOR) pathway, which is crucial for cell growth, metabolism, and proliferation.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "comparative genomics",
      "eco_type": "literature review",
      "source": "extracted"
    },
    {
      "id": "PMC11729386:discussion:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC11729386",
      "text_span_id": "discussion_2",
      "text": "Dysregulated Wnt/\u03b2-catenin signaling is implicated in ~40% of HCC cases. This pathway's aberrant activation, often due to mutations in components like CTNNB1 (encoding \u03b2-catenin), plays a significant role in HCC pathogenesis.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "comparative genomics",
      "eco_type": "literature review",
      "source": "extracted"
    }
