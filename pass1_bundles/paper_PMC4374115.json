  "evidence_entities": [
    {
      "id": "extracted_paper:introduction:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper",
      "text_span_id": "intro_0",
      "text": "Cushing's disease is a rare disorder characterized by overproduction of ACTH from a pituitary adenoma leading to hypercortisolemia that in turn leads to increased morbidity and mortality.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted_paper:results:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper",
      "text_span_id": "results_0",
      "text": "Recent evidence suggests that correction of hypercortisolemia may not lead to complete resolution of comorbidities associated with this condition. In particular, increased cardiovascular risk may persist despite long-term remission of hypercortisolemia.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted_paper:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper",
      "text_span_id": "results_1",
      "text": "This may be related to persistence of visceral adiposity, adverse adipokine profile, glucose intolerance, hypertension, dyslipidemia, atherosclerosis and a procoagulant phenotype.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted_paper:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper",
      "text_span_id": "results_2",
      "text": "Prior prolonged exposure to glucocorticoids also may have irreversible effects on the central nervous system, leading to persistent cognitive and mood alterations.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted_paper:mortality:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper",
      "text_span_id": "mortality_0",
      "text": "Multiple studies show that the standardized mortality ratio (SMR) is increased in CD (1.7\u20134.8), especially in patients with persistent hypercortisolism (3.7\u20134.2) compared to those in remission (1.8\u20133.17).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted_paper:cardiovascular:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper",
      "text_span_id": "cardiovascular_0",
      "text": "Cardiovascular risk is increased in CD patients even 5 years after remission. Compared with controls, CD patients had significantly higher waist-to-hip ratio, diastolic blood pressure, oral glucose tolerance test\u2014stimulated glucose and insulin levels, total/HDL cholesterol ratio and fibrinogen levels.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted_paper:cardiovascular:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper",
      "text_span_id": "cardiovascular_1",
      "text": "Hypertension occurs in 55\u201385 % of CD patients, but resolves after remission in only 44\u201375 %.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted_paper:thromboembolism:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper",
      "text_span_id": "thromboembolism_0",
      "text": "In one systematic review, the incidence of venous thromboembolism (VTE) in CS was 2.5\u20133.1 per 1000 persons/year compared to 1.0\u20132.0 per 1000 persons/year in the general population.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted_paper:bone:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper",
      "text_span_id": "bone_0",
      "text": "The prevalence of fractures and osteoporosis as assessed by dual energy X-ray absorptiometry (DXA) has been reported to be 15\u201350 and 38\u201350 % respectively, and may be a presenting feature of CD.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted_paper:psychiatric:0:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "extracted_paper",
      "text_span_id": "psychiatric_0",
      "text": "Most (54\u201385 %) patients with CD have some psychiatric disturbance. Depression and irritability are most common emotional lability, mania, paranoia, acute psychosis, anxiety and panic attacks also occur.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "extracted_paper:cognitive:0:llm",
      "class": "Evidence",
      "entity_id": null,
