  "evidence_entities": [
    {
      "id": "PMC_ID_NOT_PROVIDED:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_ID_NOT_PROVIDED",
      "text_span_id": "intro_1",
      "text": "Ferroptosis, an iron-dependent form of programmed cell death triggered by lipid peroxidation, has emerged as a promising therapeutic avenue due to its involvement in critical cancer progression processes including tumorigenesis, development, and therapy resistance",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro_in_vivo",
      "source": "extracted"
    },
    {
      "id": "PMC_ID_NOT_PROVIDED:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_ID_NOT_PROVIDED",
      "text_span_id": "intro_2",
      "text": "The cystine/glutamate antiporter solute carrier family 7 member 11 (SLC7A11) serves as a core regulator of ferroptosis by mediating cystine uptake for GSH synthesis, thereby suppressing lipid peroxidation and ferroptosis execution",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro_in_vivo",
      "source": "extracted"
    },
    {
      "id": "PMC_ID_NOT_PROVIDED:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_ID_NOT_PROVIDED",
      "text_span_id": "results_1",
      "text": "PTBP1 knockdown significantly suppressed tumor growth in vivo. Specifically, results from Ishikawa cell xenografts showed a significant reduction in tumor volume and weight",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vivo",
      "source": "extracted"
    },
    {
      "id": "PMC_ID_NOT_PROVIDED:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_ID_NOT_PROVIDED",
      "text_span_id": "results_2",
      "text": "PTBP1 knockdown significantly increased ROS levels, reduced intracellular GSH concentrations, and elevated levels of both MDA and ferrous ions in Ishikawa and KLE cells",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
      "source": "extracted"
    },
    {
      "id": "PMC_ID_NOT_PROVIDED:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_ID_NOT_PROVIDED",
      "text_span_id": "results_3",
      "text": "PTBP1 knockdown significantly upregulated the expression of ACSL4, while downregulating the expression of GPX4 and HSP27 in Ishikawa and KLE cells",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
      "source": "extracted"
    },
    {
      "id": "PMC_ID_NOT_PROVIDED:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_ID_NOT_PROVIDED",
      "text_span_id": "results_4",
      "text": "The fold enrichment of SLC7A11 mRNA in anti-PTBP1 immunoprecipitations, compared to anti-IgG controls, revealed approximately a four-fold increase in SLC7A11 enrichment",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
      "source": "extracted"
    },
    {
      "id": "PMC_ID_NOT_PROVIDED:results:5:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_ID_NOT_PROVIDED",
      "text_span_id": "results_5",
      "text": "The half-life of SLC7A11 mRNA was significantly shortened upon PTBP1 disruption, and SLC7A11 protein levels were also reduced in PTBP1-depleted EC cells",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
      "source": "extracted"
    },
    {
      "id": "PMC_ID_NOT_PROVIDED:results:6:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_ID_NOT_PROVIDED",
      "text_span_id": "results_6",
      "text": "Co-transfection with an SLC7A11 ORF plasmid (SLC7A11-ov) significantly increased SLC7A11 protein levels in PTBP1-depleted cells. Cell viability, which was reduced in PTBP1 knockdown cells, was partially but significantly rescued by SLC7A11 restoration",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in_vitro",
      "source": "extracted"
    }
  ],
