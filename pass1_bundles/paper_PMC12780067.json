      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "results_3",
      "text": "These effects were associated with marked upregulation of p53 and concurrent downregulation of anti-apoptotic Bcl-2 and mitochondrial ND3 genes",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": null,
      "source": "extracted"
    },
