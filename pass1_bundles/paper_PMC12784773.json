  "evidence_entities": [
    {
      "id": "PMC_FERROPTOSIS_2024:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_FERROPTOSIS_2024",
      "text_span_id": "intro_ferroptosis_definition",
      "text": "Ferroptosis is an iron-dependent form of programmed cell death that is driven by the accumulation of reactive oxygen species (ROS), leading to the formation of membrane-damaging lipid peroxides",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_FERROPTOSIS_2024:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_FERROPTOSIS_2024",
      "text_span_id": "ferroptosis_morphology",
      "text": "Morphologically, cells undergoing ferroptosis exhibit several changes in their mitochondria, including smaller size, decreased cristae, and much more condensed membranes",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_FERROPTOSIS_2024:players:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_FERROPTOSIS_2024",
      "text_span_id": "iron_fenton_reaction",
      "text": "Iron in its ferrous state (Fe2+) is required for the Fenton reaction, a chemical process in which ferrous iron ions are used in the decomposition of hydrogen peroxide (H2O2) to create reactive hydroxyl radicals",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_FERROPTOSIS_2024:players:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_FERROPTOSIS_2024",
      "text_span_id": "xct_system_function",
      "text": "The xCT system is composed of two transmembrane proteins, SLC7A11 and SLC3A2, which create a cystine/glutamate antiporter. This allows for the uptake of cystine into the cell, which is a key precursor for glutathione (GSH) synthesis",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_FERROPTOSIS_2024:suppression:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_FERROPTOSIS_2024",
      "text_span_id": "p53_slc7a11_regulation",
      "text": "p53 is crucial for restricting tumor cell growth and, in terms of ferroptosis, downregulates SLC7A11 expression, a key component of the xCT system",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_FERROPTOSIS_2024:therapeutics:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_FERROPTOSIS_2024",
      "text_span_id": "erastin_mechanism",
      "text": "Erastin acts through the inhibition of the xCT antiporter (or Xc\u2212 system) composed of both SLC7A11 and SLC3A2. Inhibition of this antiporter leads to decreased intracellular cystine uptake and subsequent depletion of GSH",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_FERROPTOSIS_2024:therapeutics:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_FERROPTOSIS_2024",
      "text_span_id": "rsl3_mechanism",
      "text": "RSL3 is another induction molecule that directly inhibits GPX4 by bypassing the need for GSH depletion",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_FERROPTOSIS_2024:therapeutics:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_FERROPTOSIS_2024",
      "text_span_id": "sorafenib_ferroptosis",
      "text": "An HCC study has shown that sorafenib enhances ferroptosis through the inhibition of SLC7A11 and subsequent decrease in cystine uptake",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "PMC_FERROPTOSIS_2024:immune:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_FERROPTOSIS_2024",
      "text_span_id": "ifn_gamma_ferroptosis",
      "text": "IFN-\u03b3, which is secreted by CD8+ T cells, can downregulate the expression of the Xc\u2212 system (which includes SLC7A11) in tumor cells, making them more susceptible to ferroptosis",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    }
