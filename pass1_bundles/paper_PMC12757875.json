  "evidence_entities": [
    {
      "id": "paper_id:background:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "background_1",
      "text": "Despite the integration of PD-L1 inhibitors with chemotherapy, extensive-stage small-cell lung cancer (ES-SCLC) continues to portend a dismal prognosis, with a 5-year survival rate below 10%",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "systematic review",
      "eco_type": "meta-analysis",
      "source": "extracted"
    },
    {
      "id": "paper_id:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "results_1",
      "text": "DDR-IF-high tumors were characterized by a distinct biological profile, including (i) transcriptional exhaustion of the cGAS-STING innate immune pathway (p < 0.001), (ii) significantly reduced CD8+ T cell infiltration (2.3-fold fewer, p = 0.004), and (iii) a superior pooled objective response rate to PARP-ICB combinations (42% vs 18%; risk ratio 2.3, 95% CI 1.3-4.2; p = 0.003)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "systematic review",
      "eco_type": "meta-analysis",
      "source": "extracted"
    },
    {
      "id": "paper_id:methods:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "methods_1",
      "text": "The final DDR-IF score was defined using standardized coefficients: DDR-IF = 0.4 \u00d7 (HRD score) + 0.35 \u00d7 log10(TMB + 1) + 0.25 \u00d7 (STING activation score)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "systematic review",
      "eco_type": "meta-analysis",
      "source": "extracted"
    },
    {
      "id": "paper_id:section4:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "section4_1",
      "text": "A meta-analysis of six trials (2020\u20132024) confirmed that DDR-IF-high tumors (e.g., ATM/BRCA1/2-altered) show a 2.3-fold higher ORR to PARP-ICB versus DDR-IF-low (42% vs. 18%, p=0.003)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "systematic review",
      "eco_type": "meta-analysis",
      "source": "extracted"
    },
    {
      "id": "paper_id:section6:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_id",
      "text_span_id": "section6_1",
      "text": "In the SCLC-specific phase Ib trial NCT04564027, the RAD51 inhibitor CYT-0851 achieved a 38% disease control rate, with matched biopsies revealing a STING-dependent 6.8-fold increase in CXCL10 (p=0.02)",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "clinical trial",
      "eco_type": "phase I",
      "source": "extracted"
    }
  ],
