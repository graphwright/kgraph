  "evidence_entities": [
    {
      "id": "paper_1:background:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "background_1",
      "text": "Despite the integration of PD-L1 inhibitors with chemotherapy, extensive-stage small-cell lung cancer (ES-SCLC) continues to portend a dismal prognosis, with a 5-year survival rate below 10%",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "systematic review and biomarker development",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "results_1",
      "text": "DDR-IF-high tumors were characterized by a distinct biological profile, including (i) transcriptional exhaustion of the cGAS-STING innate immune pathway (p < 0.001), (ii) significantly reduced CD8+ T cell infiltration (2.3-fold fewer, p = 0.004), and (iii) a superior pooled objective response rate to PARP-ICB combinations (42% vs 18%; risk ratio 2.3, 95% CI 1.3-4.2; p = 0.003)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "systematic review and biomarker development",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:methods:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "methods_1",
      "text": "The score, constructed using elastic-net regression, incorporates homologous recombination deficiency (HRD), tumor mutational burden (TMB), and STING pathway activity",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "systematic review and biomarker development",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:methods:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "methods_2",
      "text": "The final DDR-IF score was defined using standardized coefficients: DDR-IF = 0.4 \u00d7 (HRD score) + 0.35 \u00d7 log10(TMB + 1) + 0.25 \u00d7 (STING activation score)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "systematic review and biomarker development",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "results_2",
      "text": "In the independent MSK-IMPACT validation cohort (n=152), the DDR-IF score successfully stratified patients, with DDR-IF-high status being associated with significantly improved progression-free survival on PARP-ICB regimens (HR 0.45, 95% CI 0.22-0.91)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "systematic review and biomarker development",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": "results_3",
      "text": "the DDR-IF score demonstrated superior predictive power for PARP-ICB response (AUROC = 0.81) compared to SLFN11 expression alone (AUROC = 0.64), ATM mutation status (AUROC = 0.59), or a simple TMB-PD-L1 composite model (AUROC = 0.72)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "systematic review and biomarker development",
      "eco_type": null,
      "source": "extracted"
    }
  ],
