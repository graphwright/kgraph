  "evidence_entities": [
    {
      "id": "paper:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "Breast cancer remains the most frequently diagnosed malignancy in women worldwide. In 2022, almost 2.3 million cases were diagnosed, with an estimated death toll of over 666,000",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "Hereditary breast cancer contributes to approximately 10-15% of all breast cancers",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper:introduction:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "Carriers of pathogenic BRCA2 variants have a lifetime risk of developing breast cancer ranging from 38% to 84%, while the risk of developing ovarian cancer ranges from 16.5% to 27.0%",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper:screening:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "Annual magnetic resonance imaging (MRI) remains the most sensitive screening tool for early breast cancer detection in high-risk individuals",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper:rrs:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "Prophylactic bilateral mastectomy (PBM) has been shown to reduce the incidence of breast cancer by approximately 90%",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper:rrs:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "Risk-reducing BSO was associated with reduced breast cancer-specific mortality (2% vs. 6%; HR: 0.44 (95% CI: 0.26 - 0.76)), lower ovarian cancer-specific mortality (0.4% vs. 3%; HR: 0.21 (95% CI: 0.06 - 0.80)), and decreased all-cause mortality (3% vs. 10%; HR: 0.40 (95% CI: 0.26 - 0.61))",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper:chemoprevention:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "Studies utilizing selective estrogen receptor modulators (SERMs), including tamoxifen and raloxifene, and aromatase inhibitors (AIs) such as exemestane and anastrozole, have shown significant efficacy in lowering the risk of first breast cancer among high-risk individuals",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper:chemoprevention:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper",
      "text_span_id": null,
      "text": "The adjusted HRs for contralateral breast cancer were 0.38 (95% CI: 0.27 - 0.55) for BRCA1 carriers and 0.33 (95% CI: 0.22 - 0.50) for BRCA2 carriers with tamoxifen use",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    }
  ],
