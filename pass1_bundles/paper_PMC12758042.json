  "evidence_entities": [
    {
      "id": "paper_1:introduction:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": null,
      "text": "Breast cancer remains the most common cancer globally, with approximately 5-15% of cases linked to pathogenic variants primarily in BRCA1 or BRCA2.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:introduction:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": null,
      "text": "Carriers of pathogenic BRCA2 variants have a lifetime risk of developing breast cancer ranging from 38% to 84%, while the risk of developing ovarian cancer ranges from 16.5% to 27.0%.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:screening:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": null,
      "text": "Annual magnetic resonance imaging (MRI) remains the most sensitive screening tool for early breast cancer detection in high-risk individuals.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:chemoprevention:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": null,
      "text": "Tamoxifen or raloxifene use was associated with reduced breast cancer risk (HR: 0.64; 95% CI: 0.40 - 1.03; P = 0.07) in unaffected BRCA carriers.",
      "confidence": 0.9,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:surgery:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": null,
      "text": "Prophylactic bilateral mastectomy reduces the incidence of breast cancer by approximately 90% in BRCA1/2 carriers.",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:surgery:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": null,
      "text": "Risk-reducing BSO was associated with reduced breast cancer-specific mortality (2% vs. 6%; HR: 0.44 (95% CI: 0.26 - 0.76)) and lower ovarian cancer-specific mortality (0.4% vs. 3%; HR: 0.21 (95% CI: 0.06 - 0.80)).",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "narrative review",
      "eco_type": null,
      "source": "extracted"
    },
    {
      "id": "paper_1:screening:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "paper_1",
      "text_span_id": null,
      "text": "Routine screening for ovarian cancer in average-risk women utilizing transvaginal ultrasound, cancer antigen 125 (CA-125) testing, or their combination has no significant effect on ovarian cancer mortality.",
