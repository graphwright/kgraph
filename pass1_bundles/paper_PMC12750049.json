  "evidence_entities": [
    {
      "id": "PMC_extracted:results:1:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_1",
      "text": "The mRNA expression levels of ST3Gal1 in the mucosal tissue of individuals diagnosed with UC were significantly higher than those in healthy colon mucosa (derived from healthy control individuals) (P<0.05)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in vitro",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:2:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_2",
      "text": "The TEER levels in the ST3Gal1-sh3/IEC group were significantly higher than those in the IEC and sh-Ctr/IEC groups after stimulation with 2% DSS (P<0.01)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in vitro",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:3:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_3",
      "text": "The TEER levels of the inflamed ST3Gal1-OE/IEC group were significantly lower compared with those in the IEC or Ctr/IEC groups (P<0.01)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in vitro",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:4:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_4",
      "text": "ST3Gal1 knockdown in IECs significantly increased the mRNA levels of MUC2, TFF3 and CDX2, but significantly decreased the mRNA levels of STAT3 in the inflamed stable triple culture model compared with those in the control groups (P<0.01)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in vitro",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:5:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_5",
      "text": "Overexpression of ST3Gal1 in IECs significantly reduced the mRNA levels of MUC2, TFF3 and CDX2 in the inflamed stable triple culture model compared with those in the control groups (P<0.05 or P<0.01)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in vitro",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:6:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_6",
      "text": "knockdown of ST3Gal1 significantly reduced the mRNA expression levels of IL-1\u03b2, IL-6 and IL-8 in the inflamed intestinal IEC monolayer, compared with that in the control groups (P<0.01)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in vitro",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:7:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_7",
      "text": "the overexpression of ST3Gal1 in ST3Gal1-OE/IEC cells significantly elevated the mRNA levels of IL-1\u03b2, IL-6 and IL-8 within the inflamed IEC monolayer compared with the control groups (P<0.01)",
      "confidence": 0.95,
      "extraction_method": "llm",
      "study_type": "experimental",
      "eco_type": "in vitro",
      "source": "extracted"
    },
    {
      "id": "PMC_extracted:results:8:llm",
      "class": "Evidence",
      "entity_id": null,
      "paper_id": "PMC_extracted",
      "text_span_id": "results_8",
      "text": "correlation analyses revealed positive correlations between ST3Gal1 mRNA expression and the expression levels of the cytokines IL-1\u03b2 (R=0.5675; P<0.0001), IL-6 (R=0.4117; P=0.0002), IL-8 (R=0.5765; P<0.0001) and STAT3 (R=0.4079; P=0.0003) in the lesional mucosa of patients with UC",
      "confidence": 0.95,
      "extraction_method": "llm",
